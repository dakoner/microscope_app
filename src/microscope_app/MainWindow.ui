<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle"><string>Microscope App</string></property>

  <!-- ===== Central Widget ===== -->
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="centralLayout">
    <property name="leftMargin"><number>0</number></property>
    <property name="topMargin"><number>0</number></property>
    <property name="rightMargin"><number>0</number></property>
    <property name="bottomMargin"><number>0</number></property>
    <item>
     <widget class="QSplitter" name="m_mainSplitter">
      <property name="orientation"><enum>Qt::Horizontal</enum></property>

      <!-- ===== Left Panel: Scroll Area ===== -->
      <widget class="QScrollArea" name="leftScrollArea">
       <property name="widgetResizable"><bool>true</bool></property>
       <widget class="QWidget" name="leftScrollContents">
        <layout class="QVBoxLayout" name="leftLayout">

         <!-- Outer Camera Settings Tabs (single "Camera" tab containing sub-tabs) -->
         <item>
          <widget class="QTabWidget" name="cameraSettingsTabs">
           <property name="currentIndex"><number>0</number></property>
           <widget class="QTabWidget" name="cameraTabs">
            <attribute name="title"><string>Camera</string></attribute>
            <property name="currentIndex"><number>0</number></property>

            <!-- === Exposure / Gain Tab === -->
            <widget class="QWidget" name="exposureGainPage">
             <attribute name="title"><string>Exposure / Gain</string></attribute>
             <layout class="QVBoxLayout" name="exposureGainLayout">
              <item>
               <widget class="QGroupBox" name="m_controlsGroup">
                <property name="title"><string>Exposure / Gain</string></property>
                <layout class="QFormLayout" name="controlsForm">
                 <item row="0" column="0" colspan="2">
                  <widget class="QCheckBox" name="m_chkAutoExposure">
                   <property name="text"><string>Auto Exposure</string></property>
                  </widget>
                 </item>
                 <item row="1" column="0" colspan="2">
                  <widget class="QCheckBox" name="m_chkRoi">
                   <property name="text"><string>ROI</string></property>
                  </widget>
                 </item>
                 <item row="2" column="0">
                  <widget class="QLabel" name="lblExposure">
                   <property name="text"><string>Exposure (ms):</string></property>
                  </widget>
                 </item>
                 <item row="2" column="1">
                  <widget class="QDoubleSpinBox" name="m_spinExposureTime">
                   <property name="minimum"><double>0.010000000000000</double></property>
                   <property name="maximum"><double>15000.000000000000000</double></property>
                   <property name="decimals"><number>1</number></property>
                  </widget>
                 </item>
                 <item row="3" column="0" colspan="2">
                  <widget class="QSlider" name="m_sliderExposure">
                   <property name="orientation"><enum>Qt::Horizontal</enum></property>
                   <property name="minimum"><number>0</number></property>
                   <property name="maximum"><number>10000</number></property>
                  </widget>
                 </item>
                 <item row="4" column="0">
                  <widget class="QLabel" name="lblGain">
                   <property name="text"><string>Gain:</string></property>
                  </widget>
                 </item>
                 <item row="4" column="1">
                  <widget class="QSpinBox" name="m_spinGain">
                   <property name="maximum"><number>400</number></property>
                  </widget>
                 </item>
                 <item row="5" column="0" colspan="2">
                  <widget class="QSlider" name="m_sliderGain">
                   <property name="orientation"><enum>Qt::Horizontal</enum></property>
                   <property name="maximum"><number>400</number></property>
                  </widget>
                 </item>
                 <item row="6" column="0">
                  <widget class="QLabel" name="lblAeTarget">
                   <property name="text"><string>AE Target:</string></property>
                  </widget>
                 </item>
                 <item row="6" column="1">
                  <widget class="QSpinBox" name="m_spinAeTarget">
                   <property name="maximum"><number>255</number></property>
                  </widget>
                 </item>
                 <item row="7" column="0" colspan="2">
                  <widget class="QSlider" name="m_sliderAeTarget">
                   <property name="orientation"><enum>Qt::Horizontal</enum></property>
                   <property name="maximum"><number>255</number></property>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
              <item>
               <spacer name="exposureSpacer">
                <property name="orientation"><enum>Qt::Vertical</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
               </spacer>
              </item>
             </layout>
            </widget>

            <!-- === Trigger Tab === -->
            <widget class="QWidget" name="triggerPage">
             <attribute name="title"><string>Trigger</string></attribute>
             <layout class="QVBoxLayout" name="triggerPageLayout">
              <item>
               <widget class="QGroupBox" name="m_triggerGroup">
                <property name="title"><string>Trigger Mode</string></property>
                <layout class="QVBoxLayout" name="triggerGroupLayout">
                 <item>
                  <widget class="QRadioButton" name="m_rbContinuous">
                   <property name="text"><string>Continuous</string></property>
                   <property name="checked"><bool>true</bool></property>
                   <attribute name="buttonGroup">
                    <string notr="true">m_triggerBg</string>
                   </attribute>
                  </widget>
                 </item>
                 <item>
                  <widget class="QRadioButton" name="m_rbSoftware">
                   <property name="text"><string>Software</string></property>
                   <attribute name="buttonGroup">
                    <string notr="true">m_triggerBg</string>
                   </attribute>
                  </widget>
                 </item>
                 <item>
                  <widget class="QRadioButton" name="m_rbHardware">
                   <property name="text"><string>Hardware</string></property>
                   <attribute name="buttonGroup">
                    <string notr="true">m_triggerBg</string>
                   </attribute>
                  </widget>
                 </item>
                 <item>
                  <widget class="QPushButton" name="m_btnSoftTrigger">
                   <property name="text"><string>Software Trigger</string></property>
                   <property name="enabled"><bool>false</bool></property>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
              <item>
               <widget class="QGroupBox" name="m_triggerParamsGroup">
                <property name="title"><string>Trigger Parameters</string></property>
                <layout class="QFormLayout" name="triggerParamsForm">
                 <item row="0" column="0">
                  <widget class="QLabel" name="lblTriggerCount"><property name="text"><string>Count:</string></property></widget>
                 </item>
                 <item row="0" column="1">
                  <widget class="QSpinBox" name="m_spinTriggerCount">
                   <property name="maximum"><number>10000</number></property>
                  </widget>
                 </item>
                 <item row="1" column="0">
                  <widget class="QLabel" name="lblTriggerDelay"><property name="text"><string>Delay (us):</string></property></widget>
                 </item>
                 <item row="1" column="1">
                  <widget class="QSpinBox" name="m_spinTriggerDelay">
                   <property name="maximum"><number>1000000</number></property>
                  </widget>
                 </item>
                 <item row="2" column="0">
                  <widget class="QLabel" name="lblTriggerInterval"><property name="text"><string>Interval (us):</string></property></widget>
                 </item>
                 <item row="2" column="1">
                  <widget class="QSpinBox" name="m_spinTriggerInterval">
                   <property name="maximum"><number>1000000</number></property>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
              <item>
               <widget class="QGroupBox" name="m_extTriggerGroup">
                <property name="title"><string>External Trigger</string></property>
                <layout class="QFormLayout" name="extTriggerForm">
                 <item row="0" column="0">
                  <widget class="QLabel" name="lblExtMode"><property name="text"><string>Mode:</string></property></widget>
                 </item>
                 <item row="0" column="1">
                  <widget class="QComboBox" name="m_comboExtMode">
                   <item><property name="text"><string>Rising Edge</string></property></item>
                   <item><property name="text"><string>Falling Edge</string></property></item>
                   <item><property name="text"><string>High Level</string></property></item>
                   <item><property name="text"><string>Low Level</string></property></item>
                  </widget>
                 </item>
                 <item row="1" column="0">
                  <widget class="QLabel" name="lblExtJitter"><property name="text"><string>Jitter (us):</string></property></widget>
                 </item>
                 <item row="1" column="1">
                  <widget class="QSpinBox" name="m_spinExtJitter">
                   <property name="maximum"><number>100000</number></property>
                  </widget>
                 </item>
                 <item row="2" column="0">
                  <widget class="QLabel" name="lblExtShutter"><property name="text"><string>Shutter:</string></property></widget>
                 </item>
                 <item row="2" column="1">
                  <widget class="QComboBox" name="m_comboExtShutter">
                   <item><property name="text"><string>Standard</string></property></item>
                   <item><property name="text"><string>Non-Overlap</string></property></item>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
              <item>
               <spacer name="triggerSpacer">
                <property name="orientation"><enum>Qt::Vertical</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
               </spacer>
              </item>
             </layout>
            </widget>

            <!-- === Strobe Tab === -->
            <widget class="QWidget" name="strobePage">
             <attribute name="title"><string>Strobe</string></attribute>
             <layout class="QVBoxLayout" name="strobePageLayout">
              <item>
               <widget class="QGroupBox" name="m_strobeGroup">
                <property name="title"><string>Strobe</string></property>
                <layout class="QFormLayout" name="strobeForm">
                 <item row="0" column="0">
                  <widget class="QLabel" name="lblStrobeMode"><property name="text"><string>Mode:</string></property></widget>
                 </item>
                 <item row="0" column="1">
                  <widget class="QComboBox" name="m_comboStrobeMode">
                   <item><property name="text"><string>Auto</string></property></item>
                   <item><property name="text"><string>Manual</string></property></item>
                  </widget>
                 </item>
                 <item row="1" column="0">
                  <widget class="QLabel" name="lblStrobePolarity"><property name="text"><string>Polarity:</string></property></widget>
                 </item>
                 <item row="1" column="1">
                  <widget class="QComboBox" name="m_comboStrobePolarity">
                   <item><property name="text"><string>Active Low</string></property></item>
                   <item><property name="text"><string>Active High</string></property></item>
                  </widget>
                 </item>
                 <item row="2" column="0">
                  <widget class="QLabel" name="lblStrobeDelay"><property name="text"><string>Delay (us):</string></property></widget>
                 </item>
                 <item row="2" column="1">
                  <widget class="QSpinBox" name="m_spinStrobeDelay">
                   <property name="maximum"><number>1000000</number></property>
                  </widget>
                 </item>
                 <item row="3" column="0">
                  <widget class="QLabel" name="lblStrobeWidth"><property name="text"><string>Width (us):</string></property></widget>
                 </item>
                 <item row="3" column="1">
                  <widget class="QSpinBox" name="m_spinStrobeWidth">
                   <property name="maximum"><number>1000000</number></property>
                  </widget>
                 </item>
                </layout>
               </widget>
              </item>
              <item>
               <spacer name="strobeSpacer">
                <property name="orientation"><enum>Qt::Vertical</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
               </spacer>
              </item>
             </layout>
            </widget>

           </widget> <!-- end cameraTabs -->
          </widget> <!-- end cameraSettingsTabs -->
         </item>

         <!-- Hardware Tabs -->
         <item>
          <widget class="QTabWidget" name="hardwareTabs">
           <property name="currentIndex"><number>0</number></property>
           <widget class="CNCControlPanel" name="m_cncControlPanel">
            <attribute name="title"><string>CNC</string></attribute>
           </widget>
           <widget class="QWidget" name="ledPlaceholder">
            <attribute name="title"><string>LED</string></attribute>
           </widget>
          </widget>
         </item>

         <!-- Analysis Tabs -->
         <item>
          <widget class="QTabWidget" name="m_rightTabs">
           <property name="currentIndex"><number>0</number></property>
    
           <!-- === Ruler Tab === -->
           <widget class="QWidget" name="rulerPage">
            <attribute name="title"><string>Ruler</string></attribute>
            <layout class="QVBoxLayout" name="rulerLayout">
             <item>
              <layout class="QFormLayout" name="rulerForm">
               <item row="0" column="0">
                <widget class="QLabel" name="lblRulerKnown"><property name="text"><string>Known length:</string></property></widget>
               </item>
               <item row="0" column="1">
                <widget class="QLineEdit" name="m_editRulerLen">
                 <property name="text"><string>1.0</string></property>
                 <property name="placeholderText"><string>mm</string></property>
                </widget>
               </item>
               <item row="1" column="0">
                <widget class="QLabel" name="lblRulerPxLabel"><property name="text"><string>Pixel distance:</string></property></widget>
               </item>
               <item row="1" column="1">
                <widget class="QLabel" name="m_lblRulerPx"><property name="text"><string>0.0 px</string></property></widget>
               </item>
               <item row="2" column="0">
                <widget class="QLabel" name="lblRulerCalibLabel"><property name="text"><string>Calibration:</string></property></widget>
               </item>
               <item row="2" column="1">
                <widget class="QLabel" name="m_lblRulerCalib"><property name="text"><string>N/A</string></property></widget>
               </item>
               <item row="3" column="0">
                <widget class="QLabel" name="lblRulerMeasLabel"><property name="text"><string>Measured:</string></property></widget>
               </item>
               <item row="3" column="1">
                <widget class="QLabel" name="m_lblRulerMeas"><property name="text"><string>0.00 mm</string></property></widget>
               </item>
              </layout>
             </item>
             <item>
              <widget class="QPushButton" name="m_btnRulerCalibrate">
               <property name="text"><string>Calibrate</string></property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="m_chkShowProfile">
               <property name="text"><string>Show Intensity Profile</string></property>
              </widget>
             </item>
             <item>
              <widget class="IntensityChart" name="m_intensityChart">
               <property name="visible"><bool>false</bool></property>
              </widget>
             </item>
             <item>
              <spacer name="rulerSpacer">
               <property name="orientation"><enum>Qt::Vertical</enum></property>
               <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
              </spacer>
             </item>
            </layout>
           </widget>
    
           <!-- === Color Picker Tab === -->
           <widget class="ColorPickerWidget" name="m_tabColorPicker">
            <attribute name="title"><string>Color Picker</string></attribute>
           </widget>
    
          </widget> <!-- end m_rightTabs -->
         </item>

         <!-- Left stretcher -->
         <item>
          <spacer name="leftSpacer">
           <property name="orientation"><enum>Qt::Vertical</enum></property>
           <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
          </spacer>
         </item>

        </layout>
       </widget> <!-- end leftScrollContents -->
      </widget> <!-- end leftScrollArea -->

      <!-- ===== Center Panel ===== -->
      <widget class="QWidget" name="centerWidget">
       <layout class="QVBoxLayout" name="centerLayout">
        <property name="leftMargin"><number>0</number></property>
        <property name="topMargin"><number>0</number></property>
        <property name="rightMargin"><number>0</number></property>
        <property name="bottomMargin"><number>0</number></property>
        <item>
         <widget class="QTabWidget" name="m_centerTabs">
          <property name="currentIndex"><number>0</number></property>
          <widget class="QLabel" name="m_videoLabel">
           <attribute name="title"><string>Camera</string></attribute>
           <property name="text"><string>No Camera</string></property>
           <property name="alignment"><set>Qt::AlignCenter</set></property>
           <property name="minimumSize"><size><width>320</width><height>240</height></size></property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
             <horstretch>0</horstretch>
             <verstretch>0</verstretch>
            </sizepolicy>
           </property>
          </widget>
          <widget class="QWidget" name="m_mosaicTabContainer">
           <attribute name="title"><string>Mosaic</string></attribute>
           <layout class="QVBoxLayout" name="mosaicTabLayout"/>
          </widget>
         </widget>
        </item>
        <item>
         <widget class="QPlainTextEdit" name="m_logTextEdit">
          <property name="readOnly"><bool>true</bool></property>
          <property name="maximumSize"><size><width>16777215</width><height>150</height></size></property>
          <property name="maximumBlockCount"><number>1000</number></property>
         </widget>
        </item>
       </layout>
      </widget> <!-- end centerWidget -->


     </widget> <!-- end m_mainSplitter -->
    </item>
   </layout>
  </widget> <!-- end centralwidget -->

  <!-- ===== Menu Bar ===== -->
  <widget class="QMenuBar" name="menubar">
   <widget class="QMenu" name="menuFile">
    <property name="title"><string>&amp;File</string></property>
    <addaction name="m_actionStartCamera"/>
    <addaction name="m_actionStopCamera"/>
    <addaction name="separator"/>
    <addaction name="m_actionRecord"/>
    <addaction name="m_actionSnapshot"/>
    <addaction name="separator"/>
    <addaction name="m_actionHomeAndRun"/>
   </widget>
   <widget class="QMenu" name="menuView">
    <property name="title"><string>&amp;View</string></property>
    <addaction name="m_actionRuler"/>
    <addaction name="m_actionColorPicker"/>
   </widget>
   <addaction name="menuFile"/>
   <addaction name="menuView"/>
  </widget>

  <!-- ===== Toolbar ===== -->
  <widget class="QToolBar" name="mainToolbar">
   <property name="windowTitle"><string>Main</string></property>
   <attribute name="toolBarArea"><enum>Qt::TopToolBarArea</enum></attribute>
   <attribute name="toolBarBreak"><bool>false</bool></attribute>
   <addaction name="m_actionStartCamera"/>
   <addaction name="m_actionStopCamera"/>
   <addaction name="separator"/>
   <addaction name="m_actionRecord"/>
   <addaction name="m_actionSnapshot"/>
   <addaction name="separator"/>
   <addaction name="m_actionRuler"/>
   <addaction name="m_actionColorPicker"/>
   <addaction name="separator"/>
   <addaction name="m_actionHomeAndRun"/>
  </widget>

  <!-- ===== Status Bar ===== -->
  <widget class="QStatusBar" name="statusbar"/>

  <!-- ===== Actions ===== -->
  <action name="m_actionStartCamera">
   <property name="text"><string>Start Camera</string></property>
  </action>
  <action name="m_actionStopCamera">
   <property name="text"><string>Stop Camera</string></property>
  </action>
  <action name="m_actionRecord">
   <property name="text"><string>Record</string></property>
  </action>
  <action name="m_actionSnapshot">
   <property name="text"><string>Snapshot</string></property>
  </action>
  <action name="m_actionHomeAndRun">
   <property name="text"><string>Home &amp;&amp; Run</string></property>
  </action>
  <action name="m_actionRuler">
   <property name="text"><string>Ruler</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>
  <action name="m_actionColorPicker">
   <property name="text"><string>Color Picker</string></property>
   <property name="checkable"><bool>true</bool></property>
  </action>

 </widget> <!-- end MainWindow -->

 <!-- ===== Custom Widgets ===== -->
 <customwidgets>
  <customwidget>
   <class>CNCControlPanel</class>
   <extends>QGroupBox</extends>
   <header>CNCControlPanel.h</header>
  </customwidget>
  <customwidget>
   <class>IntensityChart</class>
   <extends>QWidget</extends>
   <header>IntensityChart.h</header>
  </customwidget>
  <customwidget>
   <class>ColorPickerWidget</class>
   <extends>QWidget</extends>
   <header>ColorPickerWidget.h</header>
  </customwidget>
 </customwidgets>

 <resources/>
 <connections/>

 <buttongroups>
  <buttongroup name="m_triggerBg"/>
 </buttongroups>

</ui>
